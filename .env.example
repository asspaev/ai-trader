# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_NAME=ai_trader
DB_USER=ai_trader
DB_PASSWORD=change_me

# --- Binance (public API only, без ключей) ---
BINANCE_BASE_URL=https://api.binance.com
BINANCE_TAKER_FEE=0.001
BINANCE_TIMEOUT_SECONDS=10
BINANCE_MAX_RETRIES=3
BINANCE_RETRY_BACKOFF_BASE=1

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_RETRIES=4
OPENROUTER_RETRY_BACKOFF_BASE=3
# Опционально: используются OpenRouter для аналитики/брендинга
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=AI-Trader

# --- Модели агентов (DeepSeek через OpenRouter по умолчанию) ---
AGENT_PRICE_MODEL=deepseek/deepseek-chat
AGENT_NEWS_MODEL=deepseek/deepseek-chat
AGENT_TRADER_MODEL=deepseek/deepseek-chat
AGENT_EMBEDDING_MODEL=openai/text-embedding-3-small
AGENT_EMBEDDING_DIM=1536

# --- CryptoPanic (источник новостей) ---
CRYPTOPANIC_API_KEY=
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/v1
CRYPTOPANIC_NEWS_LIMIT_PER_CRYPTO=20
CRYPTOPANIC_TIMEOUT_SECONDS=15
CRYPTOPANIC_MAX_RETRIES=3
CRYPTOPANIC_RETRY_BACKOFF_BASE=1

# --- Scheduler ---
# Режим работы планировщика: cron | interval.
SCHEDULER_MODE=cron
# Часы тика для режима cron (UTC, CSV; 4 раза в сутки по дефолту).
SCHEDULER_CRON_HOURS=0,6,12,18
# Период тика для режима interval (минуты, должно быть > 0).
SCHEDULER_INTERVAL_MINUTES=30
# Делать ли один тик сразу после старта сервиса (только для interval-режима).
SCHEDULER_RUN_ON_STARTUP=true

# --- Trading ---
TRADING_INITIAL_CAPITAL_RUB=100000
TRADING_SYMBOLS=BTC,ETH,TON
TRADING_QUOTE_ASSET=USDT
TRADING_DECISIONS_HISTORY_LIMIT=12
TRADING_RAG_TOP_K=5
TRADING_RAG_EXCLUDE_LAST_HOURS=24
TRADING_PIPELINE_STEP_TIMEOUT_SECONDS=300

# --- Telegram ---
# Bot-token из @BotFather. Доступ к командам ограничен пользователем
# из таблицы `users` (одна init-запись), остальным отвечаем "Not authorized".
TELEGRAM_BOT_TOKEN=
# Дефолтное и максимальное N в команде /history N.
TELEGRAM_HISTORY_LIMIT_DEFAULT=10
TELEGRAM_HISTORY_LIMIT_MAX=50

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs
